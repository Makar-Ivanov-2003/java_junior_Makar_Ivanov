//////////////////////////////////////////////////////////////////
//																//
//					Item Type Information						//
//																//
//////////////////////////////////////////////////////////////////
[ITEM_TYPE_INFO] // Installer gets item type from item inf file
ITEM_PRINTER
ITEM_SCANNER
ITEM_NONDEVICE
[ITEM_TYPE_INFO_END]

[ITEM_PRINTER]
CLASS = Printer
INSTALLER = $SRC_DIR$\data\ssinst.exe
INSTALLER.VISTA = $SRC_DIR$\data\ssinstAD.exe
INSTALLER.VISTA_64 = $SRC_DIR$\data\ssinstAD.exe
INST_PARAM = "$DEST_INF$" /M"%MDL%" /V"%VIDPID%" /L"$LANG_ABBR$" /P"LPT1:"
UNINST_PARAM = "$DEST_INF$" /U /M"%MDL%"		

[ITEM_SCANNER]
CLASS = Image
INSTALLER = $SRC_DIR$\data\Wiainst.exe
INST_PARAM = "$SRC_INF$" /M"%MFG%" /W /l$LANG_ABBR$ /r
UNINST_PARAM = /U"%MODEL_NAME%" /M"%MFG%" /p 

[ITEM_NONDEVICE]
CLASS = NonDevice
INSTALLER = $SRC_DIR$\data\ssndii.exe 
INST_PARAM = "$SRC_INF$" /L $LANG_ABBR$ /D "$DEST_DIR$" /F $LANG_DIR$
UNINST_PARAM ="$SRC_INF$" /U /L $LANG_ABBR$ /F $LANG_DIR$


[SHORTCUT_INFO]
UNINST_SHORTCUT // Uninstall shortcut, It is descirbed in command file 
DR_PRINTER_SHORTCUT
MANUAL_SHORTCUT // Manual Shortcut
PRT_SOLUTION_SHORTCUT // Network Solution Shortcut
//LANGUAGE_SHORTCUT //Language Selection Shortcut

[INSTALLER_FILE_INFO]
// Main installer files
CONFIGURE_FILE 		= .\data\Ssinst.ssi
COMMAND_FILE 		= .\data\ssinst.cmd
STRING_FILE_FORMAT 	= .\data\strings\Lang_%s.str  //%s
RESOURCE_DLL 		= .\SSres.dll


//utility files
PRINTER_INST_EXE 	= .\data\ssinst.exe
INSTALLER_DLL 		= .\data\ssrun.dll
UNINSTALLER_EXE 	= .\data\SSDelAll.exe
UTILITY_DLL 		= .\data\Ssutil.dll
//REMOTE_INSTALL_DLL 	= .\data\SSrmtist.dll
DIAGNOSIS_DLL 		= .\data\Ssdiag.dll
NETWORKMAN_DLL  	= .\data\ssnetman.dll
PREINSTALLER_DLL	= .\data\SSpre.dll

// Test Page DLL ==> Default is .\data\ssdiag.dll
//TESTPAGE_DLL		= .\data\sstest.dll


// Open File
SSOPEN_EXE			= .\data\SsOpen.exe
// Search AVI file
SEARCH_AVI_FILE	= .\data\search.avi


//////////////////////////////////////////////////////////////////////////////////////////////////
//																								//			
//						Pre-Install Section(It is used by pre-installer							//
//																								//
//////////////////////////////////////////////////////////////////////////////////////////////////
[PRE_INSTALL]
COPY = USBINF
COPY = USBDriverFile_98
COPY = USBDriverFile_ME
COPY = VirtualPrtFile
COPY = VirtualPrtInfFile
COPY = VECPFile32
COPY = VECPFile64
COPY = VECPFileVISTA32
COPY = VECPFileVISTA64
COPY = VECPFileNT
COPY = PRINTER_2KXP
COPY = PRINTER_XP64
COPY = PRINTER_VISTA
COPY = PRINTER_VISTA64
INF = INF_2KXP
INF = INF_XP64
INF = CompositeINF
EXEFILE = SVCMAN
EXEFILE = SCANNER_9XME
EXEFILE = SCANNER_2KXP
EXEFILE = SCANNER_XP64
EXEFILE = SCANNER_VISTA
EXEFILE = SCANNER_VISTA64
REGISTRY = SetRegINF_98
REGISTRY = SetRegINF_ME

[PRE_INSTALL_END]

[USBDriverFile_98]
SUPPORTED_OS = WIN98
FILE = "$SRC_DIR$\USB\usbmon.dll","$SYS_DIR$\usbmon.dll",0
FILE = "$SRC_DIR$\USB\usbprint.cat","$SYS_DIR$\usbprint.cat",0
FILE = "$SRC_DIR$\USB\usbprint.sys","$SYS_DIR$32\drivers\usbprint.sys",0
[USBDriverFile_98_END]

[USBDriverFile_ME]
SUPPORTED_OS = WINME
FILE = "$SRC_DIR$\USB\usbprint.cat","$SYS_DIR$\usbprint.cat",0
FILE = "$SRC_DIR$\USB\usbprint.sys","$SYS_DIR$32\drivers\usbprint.sys",0
[USBDriverFile_ME_END]

[VirtualPrtFile]
SUPPORTED_OS = WIN98,WINME
FILE = "$SRC_DIR$\USB\ssprint.dl_","$SYS_DIR$\ssprint.dll",0
FILE = "$SRC_DIR$\USB\ssprint.dr_","$SYS_DIR$\ssprint.drv",0
FILE = "$SRC_DIR$\USB\ssprint.ex_","$SYS_DIR$\ssprint.exe",0
[VirtualPrtFile_END]

[VirtualPrtInfFile]
SUPPORTED_OS = WIN98,WINME
FILE = "$SRC_DIR$\USB\ssprint.in_","$WIN_DIR$\INF\ssprint.inf",1
[VirtualPrtInfFile.END]

[VECPFile32]
SUPPORTED_OS = WIN2K,WINXP
FILE = "$SRC_DIR$\Data\VECP\WINXP\DGIVECP.SYS","$SYS_DIR$\drivers\DGIVECP.SYS",0
[VECPFile32_END]


[VECPFile64]
SUPPORTED_OS = WIN64
FILE = "$SRC_DIR$\Data\VECP\WIN64\DGIVECP.SYS","$SYS_DIR$\drivers\DGIVECP.SYS",0
FILE = "$SRC_DIR$\Data\VECP\WIN64\SSPORT.SYS","$SYS_DIR$\drivers\SSPORT.SYS",0
IS64 = 1
[VECPFile64_END]

[VECPFileNT]
SUPPORTED_OS = WINNT
FILE = "$SRC_DIR$\Data\VECP\WINNT\DGIVECP.SYS","$SYS_DIR$\drivers\DGIVECP.SYS",0
[VECPFileNT_END]

[VECPFileVISTA32]
SUPPORTED_OS = VISTA
FILE = "$SRC_DIR$\Data\VECP\VISTA\DGIVECP.SYS","$SYS_DIR$\drivers\DGIVECP.SYS",0
FILE = "$SRC_DIR$\Data\VECP\VISTA\SSPORT.SYS","$SYS_DIR$\drivers\SSPORT.SYS",0
[VECPFileVISTA32_END]

[VECPFileVISTA64]
SUPPORTED_OS = VISTA_64
FILE = "$SRC_DIR$\Data\VECP\VISTA_64\DGIVECP.SYS","$SYS_DIR$\drivers\DGIVECP.SYS",0
FILE = "$SRC_DIR$\Data\VECP\VISTA_64\SSPORT.SYS","$SYS_DIR$\drivers\SSPORT.SYS",0
IS64 = 1
[VECPFileVISTA64_END]


[SetRegINF_98]
SUPPORTED_OS = WIN98
ROOTKEY = HKLM
KEYNAME = System\CurrentControlSet\control\InstalledFiles\
VALUE = REG_BINARY,usbmon.dll,0B 00
VALUE = REG_BINARY,usbprint.cat,0B 00
VALUE = REG_BINARY,ssprint.dll,0B 00
VALUE = REG_BINARY,ssprint.drv,0B 00
VALUE = REG_BINARY,ssprint.exe,0B 00
[SetRegINF_98_END]

[SetRegINF_ME]
SUPPORTED_OS = WINME
ROOTKEY = HKLM
KEYNAME = System\CurrentControlSet\control\InstalledFiles\
VALUE = REG_BINARY,usbprint.cat,0B 00
VALUE = REG_BINARY,ssprint.dll,0B 00
VALUE = REG_BINARY,ssprint.drv,0B 00
VALUE = REG_BINARY,ssprint.exe,0B 00
[SetRegINF_ME_END]

[USBINF]
SUPPORTED_OS = WIN98,WINME
FILE = "$SRC_DIR$\USB\usbprint.in_","$WIN_DIR$\INF\usbprint.inf",1
[USBINF_END]

[CompositeINF]
SUPPORTED_OS = WIN98
INFFILE = "$SRC_DIR$\USB\sscomdev.inf"
[CompositeINF_END]

[SVCMAN]
SUPPORTED_OS = WINNT,WIN2K,WINXP,WIN64,VISTA,VISTA_64
FILE = $SRC_DIR$\DATA\VECP\VISTA_64\sskinst.exe
[SVCMAN_END]


[PRINTER_2KXP]
SUPPORTED_OS = WIN2K,WINXP
DIRECTORY = %DEFAULT_PRINTER_PATH%\WINXP_2000_VISTA_32, $SYS_DIR$\DRIVERS\%MFG%\%MODEL_NAME%,1,1
[PRINTER_2KXP_END]

[PRINTER_XP64]
SUPPORTED_OS = WIN64
DIRECTORY = %DEFAULT_PRINTER_PATH%\WINXP_VISTA_64, $WIN_DIR$\DRIVERS\%MFG%\%MODEL_NAME%,1,1
[PRINTER_XP64_END]

[PRINTER_VISTA]
SUPPORTED_OS = VISTA
DIRECTORY = %DEFAULT_PRINTER_PATH%\WINXP_2000_VISTA_32, $SYS_DIR$\DRIVERS\%MFG%\%MODEL_NAME%\,1,1
[PRINTER_XP64_END]

[PRINTER_VISTA64]
SUPPORTED_OS = VISTA_64
DIRECTORY = %DEFAULT_PRINTER_PATH%\WINXP_VISTA_64, $WIN_DIR$\DRIVERS\%MFG%\%MODEL_NAME%\,1,1
[PRINTER_VISTA64_END]

[INF_2KXP]
SUPPORTED_OS = WIN2K,WINXP,VISTA
INF = $SYS_DIR$\DRIVERS\%MFG%\%MODEL_NAME%\%DEFAULT_PRINTER_INF%
[INF_2KXP_END]

[INF_XP64]
SUPPORTED_OS = WIN64,VISTA_64
INF = $WIN_DIR$\DRIVERS\%MFG%\%MODEL_NAME%\%DEFAULT_PRINTER_INF%
[INF_XP64_END]

[SCANNER_9XME]
SUPPORTED_OS = WIN98, WINME 
FILE = $SRC_DIR$\Data\WiaInst.exe "$SRC_DIR$\SCANNER\WIN98ME\%SCANNER_INF%" /P /r /w
WAIT = 1
[SCANNER_9XME_END]

[SCANNER_2KXP]
SUPPORTED_OS = WIN2K, WINXP
FILE = $SRC_DIR$\Data\WiaInst.exe "$SRC_DIR$\SCANNER\WINXP_2000_VISTA_32\%SCANNER_INF%" /P /r /w
WAIT = 1
[SCANNER_2KXP_END]

[SCANNER_XP64]
SUPPORTED_OS = WIN64
FILE = $SRC_DIR$\Data\WiaInst.exe "$SRC_DIR$\SCANNER\WINXP_VISTA_64\%SCANNER_INF%" /P /r /w
WAIT = 1
[SCANNER_XP64_END]

[SCANNER_VISTA]
SUPPORTED_OS = VISTA
FILE = $SRC_DIR$\Data\WiaInst.exe "$SRC_DIR$\SCANNER\WINXP_2000_VISTA_32\%SCANNER_INF%" /P /r /w
WAIT = 1
[SCANNER_VIST_END]

[SCANNER_VISTA64]
SUPPORTED_OS = VISTA_64
FILE = $SRC_DIR$\Data\WiaInst.exe "$SRC_DIR$\SCANNER\WINXP_VISTA_64\%SCANNER_INF%" /P /r /w
WAIT = 1
[SCANNER_VIST64_END]

