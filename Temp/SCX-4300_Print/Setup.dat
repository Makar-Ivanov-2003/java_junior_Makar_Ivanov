[OS_DEFINE]

//Windows 95
0X00010400 = WIN95

//Windows 98
0X0001040A = WIN98

//Windows ME
0X0001045A = WINME

//Windows NT 4.0
0X00020400 = WINNT

//Windows 2k
0X00020500 = WIN2K

//Windows XP
0X00020501 = WINXP

//Windows 2003
0X00020502 = WINXP

//Vista
0X00020600 = VISTA

//Windows XP 64 bit
0X00020502.64 = WIN64

//64bit Vista
0X00020600.64 = VISTA_64

//Windows 7
0X00020601 = VISTA

//64bit Windows 7
0X00020601.64 = VISTA_64

//////////////////////////////////////////////////////////////////
