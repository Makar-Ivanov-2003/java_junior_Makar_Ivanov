%MFG% = Samsung
%MDL% = SCX-4300 Series
%VIDPID% = VID_04E8&PID_342E
%MODEL_DIR% = 

%SHARE_PREFIX% = 4300

%FREE_SPACE% = 300
%UNSUPPORTED_OS% = WIN95, WIN98, WINME, WINNT

%SPL_PRINTER% = %MODEL_NAME%
