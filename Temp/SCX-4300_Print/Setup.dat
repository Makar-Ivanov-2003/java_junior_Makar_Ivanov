// 						OS Directory define						//
//																//
//////////////////////////////////////////////////////////////////

[OS_DIR]
WIN95 = WIN98ME

//Windows 98
WIN98 = WIN98ME

//Windows ME
WINME = WIN98ME

//Windows NT
WINNT = WINNT

//Windows 2k
WIN2K = WINXP_2000_VISTA_32

//Windows XP
WINXP = WINXP_2000_VISTA_32

//Windows 2003
WIN2003 = WINXP_2000_VISTA_32

//Windows XP 64
WIN64 = WINXP_VISTA_64

//Windows 2003 64
WIN2003_64 = WINXP_VISTA_64

//Windows VISTA
VISTA = WINXP_2000_VISTA_32

//Windows VISTA 64
VISTA_64 = WINXP_VISTA_64
     
     
