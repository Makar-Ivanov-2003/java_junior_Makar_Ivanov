[autorun]
open = Setup.exe
ICON = Setup.exe

////////////////////////////////////////////////
//
// For Windows 9x USB Port Driver and
//     Windws 9x/2000/XP Vender Setup
//
// Installer Version
////////////////////////////////////////////////
[INFOMATION]
VERSION =V2.10.21:02

MFG_0=Samsung
MDL_0=SCX-4300 Series

DRIVER_NAME_0=Samsung SCX-4300 Series

////////////////////////////////////////////////////////////////////////
// For Windows XP PnP . Set Printer to GDI
////////////////////////////////////////////////////////////////////////
[DeviceInstall]
DriverPath=PRINTER\SPL\WINXP_2000_VISTA_32
DriverPath=PRINTER\SPL\WINXP_VISTA_64
DriverPath=SCANNER\WINXP_2000_VISTA_32
DriverPath=SCANNER\WINXP_VISTA_64


